msgid "plugins.block.googleScholarCitation.displayName"
msgstr "Блок цитування Google Академія"

msgid "plugins.block.googleScholarCitation.description"
msgstr "Цей плагін надає блок бічної панелі, що відображає статистику цитування автора у Google Академія."

msgid "plugins.block.googleScholarCitation.settings"
msgstr "Налаштування"

msgid "plugins.block.googleScholarCitation.settings.form.scholarUrl"
msgstr "URL-адреса профілю Google Академія"

msgid "plugins.block.googleScholarCitation.settings.form.scholarUrl.description"
msgstr "Введіть повну URL-адресу профілю Google Академія (наприклад, https://scholar.google.com/citations?user=...)"

msgid "plugins.block.googleScholarCitation.settings.form.scholarUrlRequired"
msgstr "Потрібна URL-адреса профілю Google Академія."

msgid "plugins.block.googleScholarCitation.blockTitle"
msgstr "Цитування Google Академія"

msgid "plugins.block.googleScholarCitation.errorFetching"
msgstr "Не вдалося отримати дані із зазначеної URL-адреси Google Академії."

msgid "plugins.block.googleScholarCitation.notConfigured"
msgstr "Будь ласка, налаштуйте URL-адресу профілю Google Академія в налаштуваннях плагіна."

msgid "plugins.block.googleScholarCitation.settings.form.updateFrequency"
msgstr "Частота оновлення"

msgid "plugins.block.googleScholarCitation.settings.form.updateFrequency.description"
msgstr "Виберіть, як часто потрібно оновлювати дані про цитування в Google Академії. Кешування зменшує час завантаження сторінки."

msgid "plugins.block.googleScholarCitation.settings.form.updateFrequency.daily"
msgstr "Щодня"

msgid "plugins.block.googleScholarCitation.settings.form.updateFrequency.weekly"
msgstr "Щотижня"

msgid "plugins.block.googleScholarCitation.settings.form.updateFrequency.monthly"
msgstr "Щомісяця"

msgid "plugins.block.googleScholarCitation.updatedDaily"
msgstr "Оновлюється щодня"

msgid "plugins.block.googleScholarCitation.updatedWeekly"
msgstr "Оновлюється щотижня"

msgid "plugins.block.googleScholarCitation.updatedMonthly"
msgstr "Оновлюється щомісяця"

msgid "plugins.block.googleScholarCitation.lastUpdate"
msgstr "Останнє оновлення:"


msgid "plugins.block.googleScholarCitation.settings.form.histogramColor"
msgstr "Histogram Color"

msgid "plugins.block.googleScholarCitation.settings.form.histogramColor.description"
msgstr "Choose a custom color for the citation histogram bars. Leave empty or as default to use Google Scholar's default styling."

msgid "plugins.block.googleScholarCitation.settings.form.labelColor"
msgstr "Label Color"

msgid "plugins.block.googleScholarCitation.settings.form.labelColor.description"
msgstr "Choose a custom color for the text and labels in the citation block."
