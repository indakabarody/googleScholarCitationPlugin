msgid "plugins.block.googleScholarCitation.displayName"
msgstr "Google Scholar Zitat-Block"

msgid "plugins.block.googleScholarCitation.description"
msgstr "Dieses Plugin bietet einen Seitenleistenblock, der die Google Scholar-Zitatstatistiken eines Autors anzeigt."

msgid "plugins.block.googleScholarCitation.settings"
msgstr "Einstellungen"

msgid "plugins.block.googleScholarCitation.settings.form.scholarUrl"
msgstr "Google Scholar Profil-URL"

msgid "plugins.block.googleScholarCitation.settings.form.scholarUrl.description"
msgstr "Geben Sie die vollständige URL zum Google Scholar-Profil ein (z. B. https://scholar.google.com/citations?user=...)"

msgid "plugins.block.googleScholarCitation.settings.form.scholarUrlRequired"
msgstr "Eine Google Scholar-Profil-URL ist erforderlich."

msgid "plugins.block.googleScholarCitation.blockTitle"
msgstr "Google Scholar Zitate"

msgid "plugins.block.googleScholarCitation.errorFetching"
msgstr "Daten von der angegebenen Google Scholar-URL konnten nicht abgerufen werden."

msgid "plugins.block.googleScholarCitation.notConfigured"
msgstr "Bitte konfigurieren Sie die Google Scholar-Profil-URL in den Plugin-Einstellungen."

msgid "plugins.block.googleScholarCitation.settings.form.updateFrequency"
msgstr "Aktualisierungshäufigkeit"

msgid "plugins.block.googleScholarCitation.settings.form.updateFrequency.description"
msgstr "Wählen Sie aus, wie oft die Google Scholar-Zitatdaten aktualisiert werden sollen. Caching reduziert die Ladezeit der Seite."

msgid "plugins.block.googleScholarCitation.settings.form.updateFrequency.daily"
msgstr "Täglich"

msgid "plugins.block.googleScholarCitation.settings.form.updateFrequency.weekly"
msgstr "Wöchentlich"

msgid "plugins.block.googleScholarCitation.settings.form.updateFrequency.monthly"
msgstr "Monatlich"

msgid "plugins.block.googleScholarCitation.updatedDaily"
msgstr "Täglich aktualisiert"

msgid "plugins.block.googleScholarCitation.updatedWeekly"
msgstr "Wöchentlich aktualisiert"

msgid "plugins.block.googleScholarCitation.updatedMonthly"
msgstr "Monatlich aktualisiert"

msgid "plugins.block.googleScholarCitation.lastUpdate"
msgstr "Zuletzt aktualisiert:"

